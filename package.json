{
  "name": "jfranciscosousa.com",
  "private": true,
  "scripts": {
    "clean": "rm -rf .astro .jampack dist node_modules",
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "build-prod": "astro build && jampack ./dist",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "prettier --check .",
    "format": "prettier --write .",
    "ts-check": "astro sync && tsc --noEmit --skipLibCheck",
    "a11y": "npx pa11y-ci dist/*.html dist/**/*.html dist/**/**/*.html",
    "ci": "npm run lint && npm run ts-check && npm run build-prod && npm run a11y"
  },
  "devDependencies": {
    "@divriots/jampack": "^0.34.1",
    "@types/markdown-it": "^14.1.2",
    "@types/sanitize-html": "^2.16.1",
    "@types/xml2js": "^0.4.14",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@astrojs/markdown-remark": "^7.2.0",
    "@astrojs/mdx": "^7.0.0",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.3",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.1",
    "astro": "^7.0.3",
    "astro-remote": "^0.3.4",
    "date-fns": "^4.4.0",
    "markdown-it": "^14.2.0",
    "node-addon-api": "^8.9.0",
    "node-gyp": "^13.0.0",
    "prettier": "^3.9.0",
    "rehype-plugin-image-native-lazy-loading": "^1.2.0",
    "rel-to-abs": "^0.1.0",
    "remark-code-titles": "^0.1.2",
    "sanitize-html": "^2.17.5",
    "sharp": "^0.35.2",
    "tailwindcss": "^4.3.1",
    "xml2js": "^0.6.2"
  },
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=22.x"
  }
}
