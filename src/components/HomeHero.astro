---
import siteData from "~/lib/siteData";

const { email } = siteData.socials;
---

<section class="not-prose mb-12 md:mb-10">
  <p class="text-wash-light text-sm">$ whoami</p>
  <h1 class="mt-2 text-3xl md:text-2xl font-semibold tracking-tight">
    Francisco Sousa
  </h1>
  <p class="mt-4 max-w-prose text-lg md:text-base text-wash-light">
    Software engineer building web apps and agents. Currently shaping the
    foundations of payroll systems at <a
      class="text-accent hover:opacity-100"
      href="https://remote.com"
      target="_blank"
      rel="noopener external">Remote</a
    >.
  </p>

  <div class="mt-6 flex flex-wrap items-center gap-3 text-sm">
    <a class="text-accent hover:opacity-100" href="/blog">read the blog</a>
    <span class="text-wash-dark">·</span>
    <a class="text-accent hover:opacity-100" href="/projects">see projects</a>
    <span class="text-wash-dark">·</span>
    <a class="text-accent hover:opacity-100" href={email.href} rel={email.rel}
      >get in touch</a
    >
  </div>
</section>

<hr class="not-prose mb-12 md:mb-10 border-t border-wash-dark/40" />
