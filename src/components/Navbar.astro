---
import SunIcon from "./icons/SunIcon.astro";
import MoonIcon from "./icons/MoonIcon.astro";

const pathname = Astro.url.pathname.replace(/\/+$/, "");
const links = [
  { href: "/", label: "home", match: "" },
  { href: "/about", label: "about", match: "/about" },
  { href: "/projects", label: "projects", match: "/projects" },
  { href: "/books", label: "bookshelf", match: "/books" },
  { href: "/blog", label: "blog", match: "/blog" },
];
const isActive = (match: string) => pathname === match;
---

<script is:inline>
  handleThemeToggle = () => {
    document.documentElement.classList.toggle("dark");

    if (document.documentElement.classList.contains("dark")) {
      window.localStorage.setItem("theme", "dark");
    } else {
      window.localStorage.setItem("theme", "light");
    }
  };
</script>

<nav
  class="sticky top-0 z-50 border-b border-wash-dark/60 bg-background/80 backdrop-blur supports-[backdrop-filter]:bg-background/70"
>
  <div
    class="mx-auto flex min-h-14 w-full max-w-3xl flex-wrap items-center justify-between gap-x-4 px-4 py-2"
  >
    <div class="flex items-baseline">
      <a class="font-mono text-lg font-semibold hover:opacity-100" href="/"
        >Francisco Sousa</a
      >
      <span class="text-accent/60 animate-pulse">_</span>
    </div>

    <div class="flex items-center gap-1">
      <ul class="flex flex-wrap items-center gap-x-4 font-mono text-sm">
        {
          links.map((link) => (
            <li>
              <a
                rel="prefetch"
                href={link.href}
                aria-current={isActive(link.match) ? "page" : undefined}
                class:list={[
                  "hover:opacity-100",
                  isActive(link.match)
                    ? "text-foreground underline underline-offset-4"
                    : "text-wash-light hover:text-foreground",
                ]}
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>

      <button
        class="ml-2 flex h-8 w-8 items-center justify-center text-wash-light hover:text-foreground [&_svg]:h-4 [&_svg]:w-4"
        title="Toggle dark/light mode"
        onclick="handleThemeToggle()"
        aria-label="Toggle dark or light mode"
      >
        <span class="sun-icon"><SunIcon /></span>
        <span class="moon-icon"><MoonIcon /></span>
      </button>
    </div>
  </div>
</nav>

<style>
  .moon-icon {
    display: none;
  }
  :global(html.dark) .moon-icon {
    display: inline;
  }
  :global(html.dark) .sun-icon {
    display: none;
  }
</style>
